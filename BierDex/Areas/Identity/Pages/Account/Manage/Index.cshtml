@page
@model IndexModel
@{
    ViewData["Title"] = "Profiel";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="space-y-6">
    <div>
        <h3 class="text-xl font-black text-gray-900 uppercase tracking-tight">Openbaar Profiel</h3>
        <p class="text-sm text-gray-500">Beheer hoe je verschijnt op BierDex.</p>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <form id="profile-form" method="post" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm font-medium bg-red-50 p-3 rounded-lg" role="alert"></div>
        
        <div>
            <label asp-for="Username" class="block text-xs font-black text-gray-400 mb-1 uppercase tracking-widest ml-1">Gebruikersnaam</label>
            <div class="relative">
                <input asp-for="Username" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all bg-gray-50/50" placeholder="BierKoning123" />
                <span asp-validation-for="Username" class="text-red-500 text-xs mt-1 block ml-1"></span>
            </div>
        </div>

        <div class="pt-2">
            <button id="update-profile-button" type="submit" class="w-full md:w-auto px-10 py-3 rounded-xl bg-[linear-gradient(135deg,#F2A900,#D18F00)] text-white font-black text-sm shadow-lg shadow-amber-200/50 hover:scale-[1.02] active:scale-95 transition-all uppercase tracking-widest">
                Opslaan
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
