@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Wachtwoord hersteld";
}

<div class="max-w-md mx-auto py-12 text-center">
    <div class="relative inline-block mb-8">
        <div class="text-6xl relative z-10">✅</div>
        <div class="absolute inset-0 bg-green-200 blur-2xl opacity-30 rounded-full scale-150"></div>
    </div>

    <h1 class="text-3xl font-black tracking-tight text-gray-900 uppercase">Gelukt!</h1>
    <p class="text-gray-500 mt-2 text-lg">Je wachtwoord is succesvol gewijzigd.</p>
    
    <div class="w-16 h-1 bg-[linear-gradient(135deg,#F2A900,#D18F00)] mx-auto my-6 rounded-full"></div>

    <div class="mt-10">
        <a asp-page="./Login" class="block w-full py-4 rounded-xl bg-[linear-gradient(135deg,#F2A900,#D18F00)] text-white font-black text-lg shadow-xl shadow-amber-200/50 hover:scale-[1.02] active:scale-95 transition-all">
            DIRECT INLOGGEN
        </a>
    </div>

    <div class="mt-6">
        <a href="/" class="text-sm font-bold text-gray-400 hover:text-gray-600 transition-colors">
            Terug naar de homepage
        </a>
    </div>
</div>