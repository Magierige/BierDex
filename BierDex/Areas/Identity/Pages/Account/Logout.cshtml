@page
@model LogoutModel
@{
    ViewData["Title"] = "Uitloggen";
}

<div class="max-w-md mx-auto py-12 text-center">
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="mb-8">
                <div class="text-6xl mb-6">👋</div>
                <h1 class="text-3xl font-black tracking-tight text-gray-900 uppercase">Wil je uitloggen?</h1>
                <p class="text-gray-500 mt-2">We hopen je snel weer te zien voor een volgend biertje.</p>
                <div class="w-16 h-1 bg-[linear-gradient(135deg,#F2A900,#D18F00)] mx-auto mt-6 rounded-full"></div>
            </div>

            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="w-full py-4 rounded-xl bg-[linear-gradient(135deg,#F2A900,#D18F00)] text-white font-black text-lg shadow-xl shadow-amber-200/50 hover:scale-[1.02] active:scale-95 transition-all">
                    JA, LOG MIJ UIT
                </button>
            </form>
            
            <div class="mt-6">
                <a href="/" class="text-sm font-bold text-gray-400 hover:text-gray-600 transition-colors">
                    Nee, breng me terug naar Home
                </a>
            </div>
        }
        else
        {
            <div class="animate-in fade-in zoom-in duration-500">
                <div class="text-6xl mb-6">🍻</div>
                <h1 class="text-3xl font-black tracking-tight text-gray-900 uppercase">Tot ziens!</h1>
                <p class="text-gray-500 mt-2 text-lg">Je bent nu veilig uitgelogd.</p>
                
                <div class="mt-10 space-y-4">
                    <a href="/" class="block w-full py-4 rounded-xl bg-gray-900 text-white font-black text-lg hover:bg-gray-800 transition-all">
                        TERUG NAAR HOME
                    </a>
                    <a asp-page="./Login" class="block w-full py-4 rounded-xl border-2 border-gray-100 font-black text-gray-600 hover:bg-gray-50 transition-all">
                        WEER INLOGGEN
                    </a>
                </div>
            </div>
        }
    }
</div>