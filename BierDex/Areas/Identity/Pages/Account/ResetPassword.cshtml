@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Wachtwoord herstellen";
}

<div class="max-w-md mx-auto py-4">
    <div class="text-center mb-10">
        <h1 class="text-3xl font-black tracking-tight text-gray-900 uppercase">Wachtwoord resetten</h1>
        <p class="text-gray-500 mt-2">Stel een nieuw, veilig wachtwoord in voor je account.</p>
        <div class="w-16 h-1 bg-[linear-gradient(135deg,#F2A900,#D18F00)] mx-auto mt-4 rounded-full"></div>
    </div>

    <form method="post" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm font-medium bg-red-50 p-3 rounded-lg" role="alert"></div>
        <input asp-for="Input.Code" type="hidden" />

        <div>
            <label asp-for="Input.Email" class="block text-xs font-black text-gray-400 mb-1 uppercase tracking-widest ml-1">Emailadres</label>
            <input asp-for="Input.Email" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all bg-gray-50/50" autocomplete="username" aria-required="true" placeholder="naam@voorbeeld.nl" />
            <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1 block ml-1"></span>
        </div>

        <div>
            <label asp-for="Input.Password" class="block text-xs font-black text-gray-400 mb-1 uppercase tracking-widest ml-1">Nieuw Wachtwoord</label>
            <input asp-for="Input.Password" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all bg-white" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1 block ml-1"></span>
        </div>

        <div>
            <label asp-for="Input.ConfirmPassword" class="block text-xs font-black text-gray-400 mb-1 uppercase tracking-widest ml-1">Bevestig Wachtwoord</label>
            <input asp-for="Input.ConfirmPassword" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all bg-white" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs mt-1 block ml-1"></span>
        </div>

        <div class="pt-2">
            <button type="submit" class="w-full py-4 rounded-xl bg-[linear-gradient(135deg,#F2A900,#D18F00)] text-white font-black text-lg shadow-xl shadow-amber-200/50 hover:scale-[1.02] active:scale-95 transition-all">
                WACHTWOORD OPSLAAN
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}